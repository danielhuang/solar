enum Option#[T] {
    Some(T),
    None,
}

struct Node {
    next: &Option#[Node],
}

fn main() {
    let none: Option#[Node] = Option#[Node]::None;
    let node = Node { next: none& };
    for _ in 0..100000000 {
        let wrapped: Option#[Node] = Option#[Node]::Some(node);
        node = Node { next: wrapped& };
    }
}
