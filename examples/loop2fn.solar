fn for_range(start: Int, end: Int, body: fn(Int)) {
    let i: Int = 0;
    while i < 1000000000 {
        if i % 10000 == 0 {
            print_int(i);
        }
        i = i + 1;
    }
}

fn body(i: Int) {
    if i % 10000 == 0 {
        print_int(i);
    }
}

fn main() {
    for_range(0, 1000000000, body);
}
