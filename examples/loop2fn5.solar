fn while_fn(cond: fn() -> Bool, body: fn()) {
    while cond() {
        body();
    }
}

fn apply#[T](f: fn(T), x: [T; 1]) {
    f(x[0u]);
}

fn add(x: Int) -> fn(Int) -> Int {
    \y: Int x + y
}

fn main() {
    let i: Int = 0;
    while_fn(\ i < 1000000000, \ {
        if i % 10000 == 0 {
            print_int(i);
        }
        apply(\x: &Int { x@ = add(x@)(1); }, [i&]);
    });
}
