enum Option#[T] {
    Some(T),
    None,
}

struct Node {
    next: Option#[&Node],
}

fn main() {
    let node = Node { next: Option#[&Node]::None };
    for _ in 0..100000000 {
        let wrapped = Option#[&Node]::Some(node&);
        let old_node = node&;
        node = Node { next: wrapped };
        old_node@.next = Option#[&Node]::None;
    }
}
