import intrinsics from "@intrinsics";

// Throws when its argument is too big; otherwise returns normally.
fn checked(n: Int) {
    if n > 10 {
        intrinsics::throw("too big"&);
    }
    println("checked ok"&);
}

fn main() {
    // 1. Body completes without throwing — handler not run.
    intrinsics::try(\ {
        checked(3);
        println("no throw"&);
    }, \ msg: &[Uint8] {
        println("UNEXPECTED handler"&);
    });

    // 2. Body throws — handler runs with the message, then control resumes.
    intrinsics::try(\ {
        checked(99);
        println("UNREACHABLE after throw"&);
    }, \ msg: &[Uint8] {
        println("caught:"&);
        println(msg);
    });

    // 3. Throw from a nested call across a closure boundary, caught here.
    intrinsics::try(\ {
        checked(50);
    }, \ msg: &[Uint8] {
        println("caught nested:"&);
        println(msg);
    });

    println("done"&);
}
