fn abs(x: Int) {
    if x < 0 {
        0 - x
    } else {
        x
    }
}

fn abs2(x: Int) {
    if x < 0 {
        0 - x
    } else if x == 0 {
        0
    } else {
        x
    }
}

fn main() {
    print_int(abs(0 - 100)); // 100
    print_int(abs(30)); // 30
    print_int(abs2(0 - 100)); // 100
    print_int(abs2(30)); // 30
}
