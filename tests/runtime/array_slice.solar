fn main() {
  // basic slice read
  let a: [Int] = [10, 20, 30, 40, 50];
  print_int(a[1u..3u][0u]);   // 20
  print_int(a[1u..3u][1u]);   // 30

  // slice assignment copies elements
  a[1u..3u] = a[3u..5u];
  print_int(a[1u]);            // 40
  print_int(a[2u]);            // 50

  // slice reference — writes propagate back
  let r: &[Int] = a[0u..2u]&;
  r@[0u] = 99;
  print_int(a[0u]);            // 99

  // empty slice
  let e: [Int] = a[2u..2u];
  // (nothing to print, but it shouldn't panic)

  // slice of fixed-size array
  let f: [Int; 4] = [1, 2, 3, 4];
  print_int(f[1u..3u][0u]);   // 2
  print_int(f[1u..3u][1u]);   // 3

  // let binding from slice
  let g: [Int] = a[1u..4u];
  print_int(g[0u]);             // 40
  print_int(g[1u]);             // 50
  print_int(g[2u]);             // 40

  // nested slice
  let b: [Int] = [100, 200, 300, 400, 500];
  print_int(b[1u..4u][1u..3u][0u]); // 300
  print_int(b[1u..4u][1u..3u][1u]); // 400
}
