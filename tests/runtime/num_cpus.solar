// num_cpus is machine-dependent, so print only invariants: it's >= 1 and
// stable across calls. All three backends share the same source of truth
// (available_parallelism), so outputs agree.
fn main() {
    let n = thread::num_cpus();
    if n >= 1u { println("at least one"&); }
    if thread::num_cpus() == n { println("stable"&); }
}
