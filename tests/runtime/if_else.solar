fn main() {
  // if-else statement: true branch
  if true {
    print_int(1);
  } else {
    print_int(0);
  }

  // if-else statement: false branch
  if false {
    print_int(0);
  } else {
    print_int(2);
  }

  // if without else (existing behavior)
  if true {
    print_int(3);
  }

  // if-else if-else chain
  let x: Int = 5;
  if x > 10 {
    print_int(0);
  } else if x > 3 {
    print_int(4);
  } else {
    print_int(0);
  }

  // if expression: true branch
  let a: Int = if true { 10 } else { 20 };
  print_int(a);

  // if expression: false branch
  let b: Int = if false { 10 } else { 20 };
  print_int(b);

  // if expression with else-if chain
  let c: Int = if false { 1 } else if true { 30 } else { 3 };
  print_int(c);

  // if expression used directly in a call
  print_int(if true { 40 } else { 0 });

  // if expression with multi-statement branches
  let d: Int = if true {
    let tmp: Int = 5;
    tmp + 45
  } else {
    0
  };
  print_int(d);
}
