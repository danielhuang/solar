// Regression: a multiline tail if/else in the LAST top-level item of a file
// used to parse as if_statement instead of the block tail (GLR tie broken
// arbitrarily at EOF), dropping the function body value ("body does not end
// with an expression"). No trailing item after pick() — that is the point.
fn main() {
    println(pick(2));
    println(pick(3));
}

fn pick(x: Int) -> Int {
    if x == 2 {
        10
    } else {
        20
    }
}