// Method tests

struct Point {
  x: Int,
  y: Int,
}

// basic method on Int
method double(self: Int) -> Int {
  self * 2
}

// method on struct
method sum(self: Point) -> Int {
  self.x + self.y
}

// method with reference receiver
method set_x(self: &Point, val: Int) {
  self@.x = val;
}

// generic method
struct Box#[T] {
  value: T,
}

method get#[T](self: Box#[T]) -> T {
  self.value
}

// generic method with extra arg
method map#[R](self: Box#[Int], f: fn(Int) -> R) -> R {
  f(self.value)
}

fn negate(x: Int) -> Int {
  0 - x
}

// method with same name as a function — separate namespace
fn double(x: Int) -> Int {
  x * 3
}

fn main() {
  // basic method on Int
  println(5.double());                  // 10

  // method on struct
  let p = Point { x: 3, y: 7 };
  println(p.sum());                     // 10

  // method with ref receiver
  let p2 = Point { x: 1, y: 2 };
  let rp = p2&;
  rp.set_x(42);
  println(p2.x);                        // 42

  // generic method
  let b = Box#[Int] { value: 99 };
  println(b.get#[Int]());               // 99

  // generic method with inference
  let b2 = Box#[Int] { value: 77 };
  println(b2.get());                    // 77

  // generic method with extra arg
  let b3 = Box#[Int] { value: 5 };
  println(b3.map#[Int](negate));        // -5

  // namespace separation: fn double != method double
  println(double(10));                   // 30 (fn double = x*3)
  println(10.double());                  // 20 (method double = x*2)
}
