// `loop { … }` as a value-producing expression (via `break <v>`), as a bare
// statement, and nested. break/continue inside a loop work as in other loops.
fn main() {
  // loop as a value
  let x = loop { break 5 };
  println(x);                  // 5

  // loop computing a value over iterations
  let i = 0;
  let sum = loop {
    i = i + 1;
    if i == 5 { break i * 10; }
  };
  println(sum);                // 50

  // bare loop statement with continue and a valueless break
  let n = 0;
  loop {
    n = n + 1;
    if n == 2 { continue; }
    if n >= 4 { break; }
    println(n);                // 1, 3
  };

  // nested loop expressions
  let r = loop {
    let inner = loop { break 7 };
    break inner + 1;
  };
  println(r);                  // 8
}
