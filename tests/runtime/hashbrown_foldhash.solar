import fh from "../../src/std/hashbrown/foldhash.solar";

fn main() {
  let h0 = fh::Hasher(); h0&.write_u64(42u64);   println(Uint(h0&.finish())); // 17103352462266903514
  let h1 = fh::Hasher(); h1&.write_u64(0u64);    println(Uint(h1&.finish())); // 6908261415171690783
  let h2 = fh::Hasher(); h2&.write_u64(1u64); h2&.write_u64(2u64);
                                                 println(Uint(h2&.finish())); // 12646608726195247393
  let h3 = fh::Hasher(); h3&.write_u32(7u32);    println(Uint(h3&.finish())); // 1980524245637793224
  let h4 = fh::Hasher(); h4&.write_u8(255u8);    println(Uint(h4&.finish())); // 799436778835710610
  let h5 = fh::Hasher(); h5&.write("hello"&);    println(Uint(h5&.finish())); // 2784080265892256596

  // long path (> 16 bytes): bytes 0..20
  let buf: [Uint8] = [0u8; 20u];
  let i = 0u;
  while i < 20u {
    buf[i] = Uint8(i);
    i = i + 1u;
  }
  let h6 = fh::Hasher(); h6&.write(buf&); println(Uint(h6&.finish()));        // 18047866850227357006

  let h7 = fh::Hasher(); println(Uint(h7&.finish()));                         // 589684135938649225
}
