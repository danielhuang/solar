fn print_bool(b: Bool) {
  if b {
    println(1);
  }
  if b == false {
    println(0);
  }
}

fn main() {
  print_bool(3 == 3);     // 1
  print_bool(3 == 4);     // 0
  print_bool(3 != 4);     // 1
  print_bool(3 != 3);     // 0
  print_bool(3 < 5);      // 1
  print_bool(5 < 3);      // 0
  print_bool(3 <= 3);     // 1
  print_bool(4 <= 3);     // 0
  print_bool(5 > 3);      // 1
  print_bool(3 > 5);      // 0
  print_bool(3 >= 3);     // 1
  print_bool(2 >= 3);     // 0
}
