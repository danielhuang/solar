struct Node {
  value: Int,
  next: &?Node,
}

fn print_bool(b: Bool) {
  if b {
    print_int(1);
  }
  if b == false {
    print_int(0);
  }
}

fn main() {
  let a: Int = 5;

  // Coerce a normal &Int into a nullable &?Int.
  let n: &?Int = a&;
  print_bool(n == null#[Int]); // 0
  print_bool(n != null#[Int]); // 1
  print_int(n@);              // 5  (deref does a null check, then loads)

  // A null nullable reference.
  let z: &?Int = null#[Int];
  print_bool(z == null#[Int]); // 1
  print_bool(z != null#[Int]); // 0

  // Round-trip &?Int -> &Int via `@&` (null check + reborrow).
  let r: &Int = n@&;
  print_int(r@);             // 5
  r@ = 9;
  print_int(a);              // 9

  // Nullable struct field.
  let tail: Node = Node { value: 100, next: null#[Node] };
  print_bool(tail.next == null#[Node]); // 1
  let head: Node = Node { value: 42, next: tail& };
  print_bool(head.next == null#[Node]); // 0
  print_int(head.next@.value);         // 100
}
