// Octal (0o) and hex (0x) integer literals, with and without type suffixes.
fn main() {
  println(0o111);          // 73
  println(0o777);          // 511
  println(0xFF);           // 255
  println(0xff);           // 255 (lowercase)
  println(0x10);           // 16
  println(Int(0o123u));    // 83  (octal + u suffix)
  println(Int(0xFFu8));    // 255 (hex + u8 suffix)
  println(Int(0xabu));     // 171 (hex digits + u suffix)
  println(0o0);            // 0
}
