fn double(x: Int) {
  x * 2
}

fn main() {
  // inferred let bindings
  let a = 10;
  println(a);              // 10

  let b = a + 5;
  println(b);              // 15

  let c = true;
  if c {
    println(1);            // 1
  }

  let arr = [1, 2, 3];
  println(arr[0u]);        // 1

  // inferred function return type
  println(double(7));      // 14

  // explicit annotations still work
  let d: Int = 42;
  println(d);              // 42
}
