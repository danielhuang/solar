// The tcp_echo test over IPv6 loopback: same round trip via "::1".
fn main() {
    let listener = net::listen("::1"&, 0u);
    let port = listener.local_port();

    let server = thread::spawn(\ {
        let conn = listener.accept();
        let msg = conn.read(64u);
        conn.write(msg);
        conn.shutdown_write();
    });

    let client = net::connect("::1"&, port);
    client.write("hello over tcp6"&);
    client.shutdown_write();

    let buf = [0u8; 64u];
    let total = 0u;
    loop {
        let n = client.read(buf[total..64u]&);
        if n == 0u { break; }
        total = total + n;
    };
    println(buf[0u..total]&);
    server.join();
}
