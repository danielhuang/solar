{
  "name": "solar-lang",
  "displayName": "Solar Language",
  "description": "Tree-sitter based syntax highlighting for the Solar programming language.",
  "version": "0.1.0",
  "publisher": "solar",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./src/extension.js",
  "scripts": {
    "build:grammar": "tree-sitter build --wasm ../tree-sitter-solar -o syntaxes/tree-sitter-solar.wasm && cp ../tree-sitter-solar/queries/highlights.scm queries/highlights.scm"
  },
  "activationEvents": [
    "onLanguage:solar"
  ],
  "contributes": {
    "languages": [
      {
        "id": "solar",
        "aliases": [
          "Solar",
          "solar"
        ],
        "extensions": [
          ".solar"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configurationDefaults": {
      "[solar]": {
        "editor.semanticHighlighting.enabled": true
      }
    }
  },
  "dependencies": {
    "web-tree-sitter": "^0.25.0"
  }
}
