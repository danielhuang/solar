{
  "name": "solar-lang",
  "displayName": "Solar Language",
  "description": "Semantic syntax highlighting for the Solar programming language.",
  "version": "0.1.0",
  "publisher": "solar",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./src/extension.js",
  "scripts": {
    "build:lsp": "cargo build --manifest-path ../Cargo.toml --release --bin lsp && mkdir -p server && cp ../target/release/lsp server/lsp"
  },
  "activationEvents": [
    "onLanguage:solar"
  ],
  "contributes": {
    "languages": [
      {
        "id": "solar",
        "aliases": [
          "Solar",
          "solar"
        ],
        "extensions": [
          ".solar"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configurationDefaults": {
      "[solar]": {
        "editor.semanticHighlighting.enabled": true
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
