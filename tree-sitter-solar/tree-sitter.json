{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "solar",
      "camelcase": "Solar",
      "title": "Solar",
      "scope": "source.solar",
      "file-types": ["solar"],
      "injection-regex": "^solar$",
      "class-name": "TreeSitterSolar"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Solar grammar for tree-sitter",
    "authors": [
      {
        "name": "yellow"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-solar"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
